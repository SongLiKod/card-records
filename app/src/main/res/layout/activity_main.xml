<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="拖拉机记牌器"
            android:textColor="#FFFFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tractor Card Tracker"
            android:textColor="#88FFFFFF"
            android:textSize="14sp" />

        <View
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:layout_marginTop="20dp"
            android:background="#FF7C4DFF" />

        <!-- Game status -->
        <TextView
            android:id="@+id/tv_game_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="状态：未启动"
            android:textColor="#AAFFFFFF"
            android:textSize="14sp" />

        <!-- Start overlay button -->
        <Button
            android:id="@+id/btn_start_overlay"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FF7C4DFF"
            android:text="@string/start_service"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp" />

        <!-- Start capture button -->
        <Button
            android:id="@+id/btn_start_capture"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF455A64"
            android:text="@string/start_capture"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp" />

        <!-- Manual add card -->
        <Button
            android:id="@+id/btn_manual_add"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF37474F"
            android:text="手动添加出牌"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp" />

        <!-- Reset game -->
        <Button
            android:id="@+id/btn_reset"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FFB71C1C"
            android:text="重置牌局"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp" />

        <!-- Settings -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF37474F"
            android:text="@string/settings"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp" />

        <!-- Bottom info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="v1.0.0 | 支持 1-4 副牌拖拉机"
            android:textColor="#66FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>

